{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "!(api)/**/*", "use": "@vercel/static" },
    { "src": "!(api)*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
